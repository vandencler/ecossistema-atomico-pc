{
  "name": "ecossistema-atomico",
  "version": "1.1.5",
  "description": "Ecossistema Atomico de Vendas - Emporio Natural",
  "main": "main.js",
  "scripts": {
    "start": "set ELECTRON_RUN_AS_NODE=& electron .",
    "dev": "set ELECTRON_RUN_AS_NODE=& electron . --dev",
    "test": "set NODE_ENV=test&& node --test tests/*.test.js",
    "lint": "eslint .",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir",
    "ml:extract": "node scripts/export_ml_data.js",
    "ml:process": "node scripts/process_ml_scores.js",
    "ml:cross-sell": "node scripts/train_cross_sell.js",
    "ml:sentiment": "node scripts/analyze_sentiment.js",
    "ml:trending": "node scripts/analyze_trending.js",
    "ml:retention": "node scripts/generate_retention_hooks.js",
    "ml:evaluate": "node scripts/evaluate_models.js",
    "ml:report": "node scripts/generate_sentiment_report.js",
    "ml:drift": "node scripts/detect_model_drift.js",
    "ml:triage": "node scripts/triage_detractors.js"
  },
  "author": "Emporio Natural",
  "build": {
    "appId": "com.atomico.ecossistema",
    "productName": "Sistema Atomico de Vendas",
    "copyright": "Copyright 2026 Emporio Natural",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "emporio-natural",
        "repo": "ecossistema-atomico"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "installerLanguages": [
        "pt_BR"
      ]
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "pdfmake": "^0.2.10",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "proxyquire": "^2.1.3"
  }
}
